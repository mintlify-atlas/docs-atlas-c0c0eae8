  "keyFeatures": [
    "HDFS: Distributed file system for fault-tolerant, high-throughput data storage",
    "YARN: Cluster resource management and job scheduling framework",
    "MapReduce: Parallel data processing framework for large-scale computations",
    "High Availability: NameNode HA and YARN ResourceManager HA support",
    "Federation: HDFS namespace federation for horizontal scaling",
    "Cloud Storage: Native connectors for AWS S3, Azure Data Lake, Google Cloud Storage",
    "Kerberos Security: Full authentication and authorization support",
    "Transparent Encryption: HDFS encryption zones for data-at-rest security",
    "DistCp: Distributed copy tool for large inter/intra-cluster data transfers",
    "Capacity Scheduler: Multi-tenant resource management with hierarchical queues"
  ],
